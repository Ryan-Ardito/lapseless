# Frontend (embedded at build time)
VITE_API_URL=http://localhost:3000

# Server
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:3000
CORS_ORIGINS=
SERVE_STATIC=false

# Database
DATABASE_URL=postgres://user:password@localhost:5432/practiceatlas

# S3 / MinIO
S3_ENDPOINT=
S3_PUBLIC_ENDPOINT=
S3_REGION=us-east-1
S3_BUCKET=practice-atlas-documents
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_SOLO=
STRIPE_PRICE_TEAM=
STRIPE_PRICE_GROWTH=
STRIPE_PRICE_SCALE=

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Email (Resend)
RESEND_API_KEY=
EMAIL_FROM=The Practice Atlas <noreply@thepracticeatlas.com>
